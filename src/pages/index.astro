---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import FeaturedProducts from '../components/home/FeaturedProducts.astro';
import CategoryShowcase from '../components/home/CategoryShowcase.astro';
import BrandStory from '../components/home/BrandStory.astro';
import AmbientDecor from '../components/ui/AmbientDecor.astro';
import { getFeaturedProducts } from '../lib/products';

const featured = await getFeaturedProducts();
---

<BaseLayout>
  <Hero />
  <FeaturedProducts entries={featured} />

  <!-- Stats strip -->
  <section class="relative overflow-hidden bg-gradient-to-br from-green-700 via-green-600 to-green-700 py-16 text-white">
    <div class="bg-cta-pattern absolute inset-0" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-8 text-center md:grid-cols-4 md:gap-12">
        <div class="stat-card" data-reveal="fade" style="--reveal-delay: 0ms">
          <div
            class="text-4xl font-black tabular-nums sm:text-5xl lg:text-6xl"
            data-counter="12"
            data-counter-suffix="+"
          >0+</div>
          <p class="mt-1.5 text-sm font-semibold text-green-200 sm:text-base">Premium Beverages</p>
        </div>
        <div class="stat-card" data-reveal="fade" style="--reveal-delay: 80ms">
          <div
            class="text-4xl font-black tabular-nums sm:text-5xl lg:text-6xl"
            data-counter="5"
            data-counter-suffix=""
          >0</div>
          <p class="mt-1.5 text-sm font-semibold text-green-200 sm:text-base">Flavor Categories</p>
        </div>
        <div class="stat-card" data-reveal="fade" style="--reveal-delay: 160ms">
          <div
            class="text-4xl font-black tabular-nums sm:text-5xl lg:text-6xl"
            data-counter="2"
            data-counter-suffix=""
          >0</div>
          <p class="mt-1.5 text-sm font-semibold text-green-200 sm:text-base">Trusted Brands</p>
        </div>
        <div class="stat-card" data-reveal="fade" style="--reveal-delay: 240ms">
          <div
            class="text-4xl font-black tabular-nums sm:text-5xl lg:text-6xl"
            data-counter="100"
            data-counter-suffix="%"
          >0%</div>
          <p class="mt-1.5 text-sm font-semibold text-green-200 sm:text-base">Quality Focused</p>
        </div>
      </div>
    </div>
  </section>

  <BrandStory />
  <CategoryShowcase />

  <!-- CTA banner -->
  <section class="relative overflow-hidden bg-gradient-to-br from-green-700 to-green-600 py-20 text-center text-white sm:py-28">
    <div class="bg-cta-pattern absolute inset-0" aria-hidden="true"></div>
    <AmbientDecor variant="cta" />

    <div class="relative z-10 mx-auto max-w-2xl px-4">
      <p class="section-label justify-center text-sm font-black uppercase tracking-widest text-green-300" data-reveal="fade">
        Get Started
      </p>
      <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl lg:text-5xl" data-reveal style="--reveal-delay: 80ms">
        Ready to taste the difference?
      </h2>
      <p class="mt-4 text-lg text-green-100" data-reveal style="--reveal-delay: 150ms">
        Explore our full range of premium beverages — a perfect flavour for every moment.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4" data-reveal style="--reveal-delay: 230ms">
        <a
          href="/products"
          class="btn-shimmer inline-flex items-center gap-2 rounded-full bg-white px-8 py-3.5 text-sm font-bold text-green-700 shadow-xl transition hover:scale-105 hover:bg-green-50 hover:shadow-2xl"
        >
          View All Products
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
          </svg>
        </a>
        <a
          href="/our-story"
          class="inline-flex items-center gap-2 rounded-full border-2 border-white/40 bg-white/10 px-8 py-3.5 text-sm font-bold text-white backdrop-blur transition hover:border-white/70 hover:bg-white/20"
        >
          Our Story
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
