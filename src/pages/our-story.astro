---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Our Story" description="Discover the story behind Arodiya Beverages — premium drinks crafted with passion.">
  <section class="bg-gradient-to-b from-green-50 to-white py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-widest text-green-600">Our Story</p>
        <h1 class="mt-3 text-4xl font-black text-stone-900 sm:text-5xl">Refreshing lives, one sip at a time</h1>
      </div>

      <div class="mt-10 space-y-6 text-lg leading-relaxed text-stone-600">
        <p>
          Arodiya Beverages brings together a family of trusted drink brands — from the natural fruit juices of
          Rahat to the bold sodas and premium waters of Hayat Beverages.
        </p>
        <p>
          Every product in our range is crafted with real ingredients, vibrant flavors, and packaging designed
          for modern lifestyles. Whether you need a refreshing juice at breakfast, a mocktail by the pool, or
          an energy drink for your next adventure — we have you covered.
        </p>
        <p>
          Our mission is simple: deliver beverages that taste as good as they look, with quality you can trust
          in every bottle.
        </p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        <div class="rounded-lg bg-white p-8 shadow-sm ring-1 ring-stone-200">
          <p class="text-4xl font-black text-green-600">12+</p>
          <p class="mt-2 font-bold text-stone-900">Product Variants</p>
          <p class="mt-1 text-sm text-stone-500">Juices, mocktails, sodas, energy & water</p>
        </div>
        <div class="rounded-lg bg-white p-8 shadow-sm ring-1 ring-stone-200">
          <p class="text-4xl font-black text-green-600">100%</p>
          <p class="mt-2 font-bold text-stone-900">Quality Focused</p>
          <p class="mt-1 text-sm text-stone-500">Natural ingredients, bold flavors</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>