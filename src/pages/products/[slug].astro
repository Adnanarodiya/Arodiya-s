---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductHero from '../../components/products/ProductHero.astro';
import NutritionPanel from '../../components/products/NutritionPanel.astro';
import RelatedProducts from '../../components/products/RelatedProducts.astro';
import { render } from 'astro:content';
import { getAllProducts, getRelatedProducts } from '../../lib/products';

export async function getStaticPaths() {
  const products = await getAllProducts();
  return products.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const product = entry.data;
const { Content } = await render(entry);
const related = await getRelatedProducts(entry);
---

<BaseLayout title={product.name} description={product.tagline} flavorColor={product.flavorColor}>
  <ProductHero entry={entry} />
  <NutritionPanel nutrition={product.nutrition} flavorColor={product.flavorColor} />

  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-4 text-lg leading-relaxed text-stone-600 [&_p]:mb-4 [&_strong]:font-bold [&_strong]:text-stone-800">
        <Content />
      </div>
    </div>
  </section>

  {
    product.gallery && product.gallery.length > 1 && (
      <section class="bg-stone-50 py-16 border-t border-stone-200">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <p class="text-sm font-bold uppercase tracking-widest text-green-600 mb-2">Visual Showcase</p>
          <h2 class="mb-8 text-3xl font-black text-stone-900">Product Gallery</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {product.gallery.map((img, idx) => {
              const isPng = img.endsWith('.png');
              const labels = [
                '01 / Studio Packshot',
                '02 / Action & Splash',
                '03 / Creative Lifestyle'
              ];
              return (
                <div class="group flex flex-col gap-3">
                  <div 
                    class="overflow-hidden rounded-2xl border border-stone-200 shadow-sm transition-all duration-300 group-hover:shadow-md aspect-square w-full"
                    style={isPng ? `background: radial-gradient(circle at center, ${product.flavorColorLight} 0%, #ffffff 80%)` : ''}
                  >
                    {isPng ? (
                      <div class="h-full w-full p-8 flex items-center justify-center">
                        <img
                          src={img}
                          alt={`${product.name} studio render`}
                          class="h-full w-full object-contain filter drop-shadow-[0_15px_20px_rgba(0,0,0,0.15)] transition-transform duration-500 ease-out group-hover:scale-105"
                          loading="lazy"
                        />
                      </div>
                    ) : (
                      <img
                        src={img}
                        alt={`${product.name} variant`}
                        class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
                        loading="lazy"
                      />
                    )}
                  </div>
                  <p class="text-xs font-bold uppercase tracking-wider text-stone-500 px-1">
                    {labels[idx] || `0${idx + 1} / Variant`}
                  </p>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    )
  }

  <RelatedProducts entries={related} />

  <section class="py-12 text-center">
    <a href="/products" class="text-sm font-bold text-green-700 hover:text-green-800">← Back to all products</a>
  </section>
</BaseLayout>