---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/products/ProductCard.astro';
import ProductFilterBar from '../../components/products/ProductFilterBar.astro';
import AmbientDecor from '../../components/ui/AmbientDecor.astro';
import { getAllProducts, categoryLabels } from '../../lib/products';
import type { ProductCategory } from '../../types/product';

const products = await getAllProducts();
const categoryParam = Astro.url.searchParams.get('category') as ProductCategory | null;
const validCategories = Object.keys(categoryLabels);
const activeCategory = categoryParam && validCategories.includes(categoryParam) ? categoryParam : null;
const filteredProducts = activeCategory
  ? products.filter((entry) => entry.data.category === activeCategory)
  : products;
---

<BaseLayout title="Products" description="Browse all Arodiya Beverages — juices, mocktails, sodas, energy drinks and more.">
  <!-- Page hero -->
  <section class="relative overflow-hidden bg-gradient-to-b from-green-50/80 to-white pb-0 pt-12 sm:pt-16">
    <div class="bg-dots absolute inset-0 opacity-25" aria-hidden="true"></div>
    <div class="bg-blobs absolute inset-0" aria-hidden="true"></div>
    <AmbientDecor variant="light" />

    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div data-reveal="fade">
        <p class="section-label text-sm font-black uppercase tracking-widest text-green-600">Our Range</p>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-stone-900 sm:text-4xl lg:text-5xl">
          All Products
        </h1>
        <p class="mt-3 max-w-2xl text-base text-stone-500 sm:text-lg">
          <span id="product-count">{filteredProducts.length}</span> premium beverages crafted for every taste and occasion.
        </p>
      </div>

      <!-- Filter bar -->
      <div class="mt-7 pb-6 sm:mt-8 sm:pb-8">
        <ProductFilterBar activeCategory={activeCategory} />
      </div>
    </div>
  </section>

  <!-- Product grid -->
  <section class="relative bg-white py-10 sm:py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-5 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
        {
          products.map((entry, i) => (
            <div
              data-product-category={entry.data.category}
              data-reveal
              style={`--reveal-delay: ${Math.min(i, 5) * 70}ms`}
              class:list={[activeCategory && entry.data.category !== activeCategory && 'hidden']}
            >
              <ProductCard entry={entry} />
            </div>
          ))
        }
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden py-20 text-center">
        <p class="text-2xl font-black text-stone-300">No products found</p>
        <a href="/products" class="mt-4 inline-block text-sm font-bold text-green-600 hover:text-green-700">
          View all products →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
