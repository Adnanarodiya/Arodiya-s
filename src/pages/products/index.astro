---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/products/ProductCard.astro';
import { getAllProducts, categoryLabels } from '../../lib/products';
import type { ProductCategory } from '../../types/product';

const products = await getAllProducts();
const categoryParam = Astro.url.searchParams.get('category') as ProductCategory | null;
const validCategories = Object.keys(categoryLabels);
const activeCategory = categoryParam && validCategories.includes(categoryParam) ? categoryParam : null;
const filteredProducts = activeCategory
  ? products.filter((entry) => entry.data.category === activeCategory)
  : products;
---

<BaseLayout title="Products" description="Browse all Arodiya Beverages — juices, mocktails, sodas, energy drinks and more.">
  <section class="bg-gradient-to-b from-green-50 to-white py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div>
        <p class="text-sm font-bold uppercase tracking-widest text-green-600">Our Range</p>
        <h1 class="mt-2 text-4xl font-black text-stone-900 sm:text-5xl">All Products</h1>
        <p class="mt-3 max-w-2xl text-lg text-stone-600">
          {filteredProducts.length} premium beverages crafted for every taste and occasion.
        </p>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/products"
          class:list={[
            'rounded-md px-5 py-2 text-sm font-bold transition',
            !activeCategory ? 'bg-green-600 text-white' : 'bg-white text-stone-600 ring-1 ring-stone-200 hover:ring-green-400',
          ]}
        >
          All
        </a>
        {
          Object.entries(categoryLabels).map(([key, label]) => (
            <a
              href={`/products?category=${key}`}
              class:list={[
                'rounded-md px-5 py-2 text-sm font-bold transition',
                activeCategory === key
                  ? 'bg-green-600 text-white'
                  : 'bg-white text-stone-600 ring-1 ring-stone-200 hover:ring-green-400',
              ]}
            >
              {label}
            </a>
          ))
        }
      </div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {filteredProducts.map((entry) => <ProductCard entry={entry} />)}
      </div>
    </div>
  </section>
</BaseLayout>