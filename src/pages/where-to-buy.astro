---
import BaseLayout from '../layouts/BaseLayout.astro';

const retailers = ['Walmart', 'Target', 'Whole Foods', 'Instacart', 'Local Retailers'];
---

<BaseLayout title="Where to Buy" description="Find Arodiya Beverages at retailers near you.">
  <section class="bg-gradient-to-b from-green-50 to-white py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <div>
        <p class="text-sm font-bold uppercase tracking-widest text-green-600">Find Us</p>
        <h1 class="mt-3 text-4xl font-black text-stone-900 sm:text-5xl">Where to Buy</h1>
        <p class="mt-4 text-lg text-stone-600">
          Arodiya Beverages are available at leading retailers and local stores. More locations coming soon.
        </p>
      </div>

      <div class="mt-10 flex flex-wrap justify-center gap-4">
        {
          retailers.map((name) => (
            <span class="rounded-lg bg-white px-6 py-4 text-sm font-bold text-stone-700 shadow-sm ring-1 ring-stone-200">
              {name}
            </span>
          ))
        }
      </div>

      <div class="mt-12 rounded-lg bg-green-600 p-8 text-white">
        <h2 class="text-xl font-bold">Can't find us nearby?</h2>
        <p class="mt-2 text-green-100">Contact us and we'll help you locate the nearest store carrying our products.</p>
        <a
          href="mailto:hello@arodiya.com"
          class="mt-6 inline-block rounded-md bg-white px-8 py-3 text-sm font-bold text-green-700 transition hover:bg-green-50"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>