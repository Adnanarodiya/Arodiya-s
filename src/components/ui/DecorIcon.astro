---
interface Props {
  name:
    | 'straw'
    | 'cone'
    | 'burger'
    | 'pizza'
    | 'lemon'
    | 'ice'
    | 'fries'
    | 'popcorn'
    | 'bubble'
    | 'splash';
  class?: string;
}

const { name, class: className = '' } = Astro.props;
---

{
  name === 'straw' && (
    <svg class:list={['decor-icon', className]} viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <rect x="28" y="8" width="8" height="44" rx="4" fill="#f43f5e" transform="rotate(12 32 30)" />
      <rect x="26" y="6" width="12" height="10" rx="3" fill="#fb7185" transform="rotate(12 32 11)" />
      <path d="M22 50c4 6 10 8 16 6" stroke="#fda4af" stroke-width="3" stroke-linecap="round" />
    </svg>
  )
}

{
  name === 'cone' && (
    <svg class:list={['decor-icon', className]} viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <path d="M18 48 L32 14 L46 48 Z" fill="#f59e0b" />
      <path d="M20 44 L32 18 L44 44 Z" fill="#fbbf24" opacity="0.5" />
      <ellipse cx="32" cy="16" rx="14" ry="10" fill="#fda4af" />
      <ellipse cx="28" cy="14" rx="5" ry="4" fill="#fecdd3" />
      <circle cx="38" cy="18" r="3" fill="#f43f5e" />
    </svg>
  )
}

{
  name === 'burger' && (
    <svg class:list={['decor-icon', className]} viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <path d="M12 28h40v6H12z" fill="#d97706" />
      <path d="M10 34h44v5H10z" fill="#84cc16" />
      <path d="M12 39h40v5H12z" fill="#fbbf24" />
      <path d="M10 44h44v6H10z" fill="#d97706" />
      <ellipse cx="32" cy="26" rx="22" ry="8" fill="#fcd34d" />
      <circle cx="22" cy="36" r="2" fill="#ef4444" />
      <circle cx="32" cy="37" r="2" fill="#ef4444" />
      <circle cx="42" cy="36" r="2" fill="#ef4444" />
    </svg>
  )
}

{
  name === 'pizza' && (
    <svg class:list={['decor-icon', className]} viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <path d="M10 50 L32 10 L54 50 Z" fill="#fbbf24" />
      <path d="M16 46 L32 16 L48 46 Z" fill="#fcd34d" opacity="0.6" />
      <circle cx="28" cy="38" r="4" fill="#ef4444" />
      <circle cx="38" cy="42" r="3.5" fill="#ef4444" />
      <circle cx="34" cy="30" r="3" fill="#ef4444" />
      <circle cx="24" cy="28" r="2.5" fill="#16a34a" />
      <circle cx="40" cy="34" r="2.5" fill="#16a34a" />
    </svg>
  )
}

{
  name === 'lemon' && (
    <svg class:list={['decor-icon', className]} viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <circle cx="32" cy="32" r="22" fill="#facc15" />
      <circle cx="32" cy="32" r="18" fill="#fde047" />
      <path d="M32 14v36M18 32h28M22 22l20 20M42 22L22 42" stroke="#eab308" stroke-width="1.5" opacity="0.5" />
      <ellipse cx="32" cy="10" rx="4" ry="6" fill="#84cc16" />
    </svg>
  )
}

{
  name === 'ice' && (
    <svg class:list={['decor-icon', className]} viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <rect x="14" y="18" width="18" height="18" rx="3" fill="#bae6fd" transform="rotate(-8 23 27)" />
      <rect x="32" y="14" width="16" height="16" rx="3" fill="#7dd3fc" transform="rotate(10 40 22)" />
      <rect x="22" y="34" width="20" height="20" rx="3" fill="#e0f2fe" transform="rotate(5 32 44)" />
    </svg>
  )
}

{
  name === 'fries' && (
    <svg class:list={['decor-icon', className]} viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <path d="M16 20 L24 52" stroke="#f59e0b" stroke-width="5" stroke-linecap="round" />
      <path d="M26 18 L32 54" stroke="#fbbf24" stroke-width="5" stroke-linecap="round" />
      <path d="M36 20 L40 52" stroke="#f59e0b" stroke-width="5" stroke-linecap="round" />
      <path d="M46 22 L48 50" stroke="#fbbf24" stroke-width="5" stroke-linecap="round" />
      <path d="M12 52h40v6H12z" fill="#ef4444" rx="2" />
    </svg>
  )
}

{
  name === 'popcorn' && (
    <svg class:list={['decor-icon', className]} viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <path d="M14 48 L18 28 L46 28 L50 48 Z" fill="#ef4444" />
      <circle cx="22" cy="24" r="7" fill="#fef3c7" />
      <circle cx="32" cy="20" r="8" fill="#fde68a" />
      <circle cx="42" cy="24" r="7" fill="#fef3c7" />
      <circle cx="27" cy="30" r="5" fill="#fde68a" />
      <circle cx="37" cy="30" r="5" fill="#fef3c7" />
    </svg>
  )
}

{
  name === 'bubble' && (
    <svg class:list={['decor-icon', className]} viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <circle cx="32" cy="32" r="20" fill="currentColor" opacity="0.15" />
      <circle cx="26" cy="26" r="5" fill="white" opacity="0.5" />
    </svg>
  )
}

{
  name === 'splash' && (
    <svg class:list={['decor-icon', className]} viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <path
        d="M32 8c0 0-8 12-8 22a8 8 0 1016 0c0-10-8-22-8-22z"
        fill="currentColor"
        opacity="0.2"
      />
      <circle cx="20" cy="40" r="5" fill="currentColor" opacity="0.15" />
      <circle cx="44" cy="38" r="4" fill="currentColor" opacity="0.15" />
      <circle cx="32" cy="48" r="3" fill="currentColor" opacity="0.12" />
    </svg>
  )
}