---
import { siteConfig, getMenu, getCopyright, socialConfig } from '../../lib/config';

const menu = getMenu('en');
const { site, params } = siteConfig;
const year = new Date().getFullYear();

const socialIcons: Record<string, string> = {
  Facebook: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
  Instagram: '<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>',
  X: '<path d="M4 4l16 16M20 4L4 20"/>',
  LinkedIn: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
};
---

<footer class="border-t border-stone-200 bg-gradient-to-b from-green-50/70 to-white text-stone-600">
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">

    <!-- Main grid -->
    <div class="grid gap-10 md:grid-cols-4 lg:gap-12">

      <!-- Brand column -->
      <div class="md:col-span-2" data-reveal="fade">
        <a href="/" class="inline-block transition-opacity hover:opacity-80">
          <img
            src={site.logo}
            alt={site.logo_text}
            class="mb-4 h-10 w-auto"
            width={site.logo_width}
            height={site.logo_height}
          />
        </a>
        <p class="max-w-sm text-sm leading-relaxed text-stone-500">
          {params.footer_description}
        </p>

        <!-- Social icons -->
        <div class="mt-6 flex items-center gap-2">
          {
            socialConfig.main.map((social) => {
              const iconPath = socialIcons[social.name] || '';
              return (
                <a
                  href={social.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={social.name}
                  class="social-icon-btn flex h-9 w-9 items-center justify-center rounded-full border border-stone-200 bg-white text-stone-500 shadow-sm hover:border-green-400 hover:bg-green-50 hover:text-green-700"
                >
                  <svg
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={iconPath}
                  />
                </a>
              );
            })
          }
        </div>
      </div>

      <!-- Explore links -->
      <div data-reveal style="--reveal-delay: 80ms">
        <h3 class="mb-4 text-xs font-black uppercase tracking-[0.15em] text-stone-900">Explore</h3>
        <ul class="space-y-2.5 text-sm">
          {
            menu.footer_menu.map((link) => (
              <li>
                <a
                  href={link.url}
                  class="group flex items-center gap-1.5 text-stone-500 transition hover:text-green-700"
                >
                  <span class="h-1 w-1 rounded-full bg-stone-300 transition group-hover:bg-green-500" />
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Categories links -->
      <div data-reveal style="--reveal-delay: 140ms">
        <h3 class="mb-4 text-xs font-black uppercase tracking-[0.15em] text-stone-900">Categories</h3>
        <ul class="space-y-2.5 text-sm">
          {
            menu.footer_quick_links.map((link) => (
              <li>
                <a
                  href={link.url}
                  class="group flex items-center gap-1.5 text-stone-500 transition hover:text-green-700"
                >
                  <span class="h-1 w-1 rounded-full bg-stone-300 transition group-hover:bg-green-500" />
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-stone-200 pt-6 sm:flex-row">
      <p class="text-xs text-stone-400">{getCopyright(year)}</p>
      <button
        id="back-to-top"
        type="button"
        class="flex items-center gap-1.5 rounded-full border border-stone-200 bg-white px-3 py-1.5 text-xs font-semibold text-stone-500 shadow-sm transition hover:border-green-400 hover:text-green-700"
        aria-label="Scroll to top"
      >
        <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 17a.75.75 0 01-.75-.75V5.612L5.29 9.77a.75.75 0 01-1.08-1.04l5.25-5.5a.75.75 0 011.08 0l5.25 5.5a.75.75 0 11-1.08 1.04L10.75 5.612V16.25A.75.75 0 0110 17z" clip-rule="evenodd" />
        </svg>
        Back to top
      </button>
    </div>
  </div>
</footer>

<script>
  document.addEventListener('astro:page-load', () => {
    document.getElementById('back-to-top')?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
