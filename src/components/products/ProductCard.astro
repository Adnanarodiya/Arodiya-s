---
import type { ProductEntry } from '../../lib/products';
import { categoryLabels } from '../../lib/products';

interface Props {
  entry: ProductEntry;
}

const { entry } = Astro.props;
const product = entry.data;

const badgeStyles: Record<string, string> = {
  new: 'bg-sky-500',
  limited: 'bg-amber-500',
  bestseller: 'bg-green-600',
  classic: 'bg-stone-600',
};
---

<a
  href={`/products/${entry.id}`}
  class="product-card group relative flex h-full flex-col overflow-hidden rounded-2xl bg-white shadow-[0_4px_24px_-6px_rgba(0,0,0,0.08)] ring-1 ring-stone-200/70 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_24px_48px_-12px_rgba(0,0,0,0.14)]"
  style={`--card-flavor: ${product.flavorColor}; --card-flavor-light: ${product.flavorColorLight}`}
>
  <article class="flex h-full flex-col" transition:name={`product-${entry.id}`}>
    <div
      class="product-stage relative flex aspect-[5/6] items-end justify-center overflow-hidden px-4 pb-3 pt-6 sm:px-5 sm:pt-8"
      style={`background: linear-gradient(160deg, color-mix(in srgb, var(--card-flavor-light) 80%, white) 0%, #ffffff 50%, color-mix(in srgb, var(--card-flavor-light) 50%, white) 100%)`}
    >
      <div
        class="absolute -right-8 -top-8 h-28 w-28 rounded-full opacity-30 blur-2xl transition duration-500 group-hover:opacity-50"
        style="background: var(--card-flavor)"
        aria-hidden="true"
      ></div>
      <div
        class="absolute -left-6 bottom-1/3 h-20 w-20 rounded-full opacity-20 blur-xl transition duration-500 group-hover:opacity-35"
        style="background: var(--card-flavor)"
        aria-hidden="true"
      ></div>
      <div
        class="absolute bottom-0 left-1/2 h-16 w-[70%] -translate-x-1/2 rounded-[100%] opacity-25 blur-md transition duration-500 group-hover:opacity-40"
        style="background: var(--card-flavor)"
        aria-hidden="true"
      ></div>

      <span
        class="absolute right-3 top-3 z-10 rounded-full border border-white/60 bg-white/85 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-stone-600 shadow-sm backdrop-blur-sm"
      >
        {categoryLabels[product.category]}
      </span>

      {
        product.badge && (
          <span
            class:list={[
              'absolute left-3 top-3 z-10 rounded-full px-2.5 py-1 text-[10px] font-black uppercase tracking-wider text-white shadow-md',
              badgeStyles[product.badge] ?? 'bg-stone-600',
            ]}
          >
            {product.badge}
          </span>
        )
      }

      <img
        src={product.image}
        alt={product.name}
        class="product-image relative z-10 max-h-[92%] w-auto max-w-full object-contain drop-shadow-[0_20px_28px_rgba(0,0,0,0.18)]"
        loading="lazy"
      />
    </div>

    <div class="relative flex flex-1 flex-col p-5">
      <div
        class="product-accent-line absolute left-0 top-0 h-1 w-full origin-left scale-x-0 transition-transform duration-300 group-hover:scale-x-100"
        style="background: var(--card-flavor)"
        aria-hidden="true"
      ></div>

      <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-stone-400">{product.brand}</p>

      <h3
        class="mt-1.5 text-lg font-black leading-tight text-stone-900 transition-colors duration-200 group-hover:text-[var(--card-flavor)]"
      >
        {product.name}
      </h3>
      <p class="mt-1 line-clamp-2 text-sm leading-snug text-stone-500">{product.tagline}</p>

      {
        product.tasteNotes.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1.5">
            {product.tasteNotes.slice(0, 2).map((note) => (
              <span
                class="rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide"
                style="background: color-mix(in srgb, var(--card-flavor-light) 70%, white); color: var(--card-flavor)"
              >
                {note}
              </span>
            ))}
          </div>
        )
      }

      <div class="mt-auto flex items-center justify-between border-t border-stone-100 pt-4">
        <span class="text-xs font-medium text-stone-400">{product.nutrition.size}</span>
        <span class="product-cta flex items-center gap-1 text-xs font-bold text-[var(--card-flavor)]">
          View
          <svg
            class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
              clip-rule="evenodd"
            />
          </svg>
        </span>
      </div>
    </div>
  </article>
</a>