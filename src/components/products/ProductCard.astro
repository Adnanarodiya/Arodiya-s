---
import type { ProductEntry } from '../../lib/products';

interface Props {
  entry: ProductEntry;
}

const { entry } = Astro.props;
const product = entry.data;

const badgeColors: Record<string, string> = {
  new: 'bg-sky-500',
  limited: 'bg-amber-500',
  bestseller: 'bg-green-600',
  classic: 'bg-stone-600',
};
---

<a
  href={`/products/${entry.id}`}
  class="product-card group block overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
  style={`--card-flavor: ${product.flavorColor}; --card-flavor-light: ${product.flavorColorLight};`}
>
  <article transition:name={`product-${entry.id}`}>
    <div 
      class="product-image-frame relative aspect-square w-full overflow-hidden p-6 transition-all duration-500 ease-out"
      style={`background: radial-gradient(circle at center, var(--card-flavor-light) 0%, #ffffff 80%)`}
    >
      {
        product.badge && (
          <span
            class:list={[
              'absolute left-4 top-4 z-10 rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-wider text-white shadow-sm',
              badgeColors[product.badge] ?? 'bg-stone-600',
            ]}
          >
            {product.badge}
          </span>
        )
      }
      <img
        src={product.image}
        alt={product.name}
        class="product-image h-full w-full object-contain filter drop-shadow-[0_15px_20px_rgba(0,0,0,0.15)] transition-transform duration-500 ease-out group-hover:scale-105"
        loading="lazy"
      />
    </div>

    <div class="space-y-2 p-5">
      <div class="flex items-center justify-between">
        <p class="text-[10px] font-black uppercase tracking-widest text-stone-400">{product.brand}</p>
        <span 
          class="h-2 w-2 rounded-full" 
          style={`background-color: var(--card-flavor)`}
        />
      </div>
      <h3 class="text-lg font-black text-stone-900 group-hover:text-[var(--card-flavor)] transition-colors duration-200">{product.name}</h3>
      <p class="line-clamp-2 text-sm text-stone-600 font-medium">{product.tagline}</p>
    </div>
  </article>
</a>