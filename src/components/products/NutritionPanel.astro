---
import type { ProductNutrition } from '../../types/product';

interface Props {
  nutrition: ProductNutrition;
  flavorColor: string;
}

const { nutrition, flavorColor } = Astro.props;
---

<section class="bg-white py-12 sm:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-2xl font-black text-stone-900 sm:text-3xl">Nutrition & Ingredients</h2>
      <div class="mt-6 rounded-lg border-2 border-stone-200 bg-stone-50">
        <div class="grid grid-cols-3 divide-x divide-stone-200 border-b border-stone-200 bg-white">
          <div class="p-5 text-center">
            <p class="text-2xl font-black" style={`color: ${flavorColor}`}>{nutrition.calories}</p>
            <p class="text-xs font-semibold uppercase tracking-wide text-stone-500">Calories</p>
          </div>
          <div class="p-5 text-center">
            <p class="text-2xl font-black" style={`color: ${flavorColor}`}>{nutrition.sugar}</p>
            <p class="text-xs font-semibold uppercase tracking-wide text-stone-500">Sugar</p>
          </div>
          <div class="p-5 text-center">
            <p class="text-lg font-black" style={`color: ${flavorColor}`}>{nutrition.size}</p>
            <p class="text-xs font-semibold uppercase tracking-wide text-stone-500">Sizes</p>
          </div>
        </div>
        <div class="p-6">
          <h3 class="text-sm font-bold uppercase tracking-wider text-stone-500">Ingredients</h3>
          <ul class="mt-3 space-y-2">
            {
              nutrition.ingredients.map((item) => (
                <li class="flex items-center gap-2 text-stone-700">
                  <span class="h-1.5 w-1.5 rounded-full" style={`background: ${flavorColor}`}></span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>