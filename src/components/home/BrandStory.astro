---
import AmbientDecor from '../ui/AmbientDecor.astro';
import DecorIcon from '../ui/DecorIcon.astro';

const highlights = [
  {
    title: 'Real Ingredients',
    description: 'Crafted with natural fruit extracts, pure spring water, and no artificial compromises.',
    icon: 'lemon' as const,
    accent: '#84cc16',
    bg: 'from-lime-50 to-green-50',
    border: '#84cc1620',
  },
  {
    title: 'Multiple Sizes',
    description: 'From on-the-go bottles to family-size jugs — refreshment for every occasion.',
    icon: 'ice' as const,
    accent: '#0ea5e9',
    bg: 'from-sky-50 to-cyan-50',
    border: '#0ea5e920',
  },
  {
    title: 'Bold Variety',
    description: 'Juices, mocktails, sodas, energy drinks and premium waters under one trusted brand family.',
    icon: 'straw' as const,
    accent: '#16a34a',
    bg: 'from-emerald-50 to-green-50',
    border: '#16a34a20',
  },
];
---

<section class="relative overflow-hidden bg-white py-20 sm:py-28">
  <div class="bg-dots absolute inset-0 opacity-25" aria-hidden="true"></div>
  <div class="bg-blobs absolute inset-0" aria-hidden="true"></div>
  <AmbientDecor variant="light" />

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Section heading -->
    <div class="mx-auto max-w-3xl text-center" data-reveal="fade">
      <p class="section-label text-sm font-black uppercase tracking-widest text-green-600">Why Arodiya</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-stone-900 sm:text-4xl lg:text-5xl">
        Made to refresh.<br class="hidden sm:block" />
        <span class="text-gradient">Built to impress.</span>
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-stone-500">
        We bring together the best of Rahat juices, Hayat beverages, and premium energy drinks —
        delivering quality you can taste in every sip.
      </p>
    </div>

    <!-- Highlight cards -->
    <div class="mt-14 grid gap-6 sm:grid-cols-3">
      {
        highlights.map((item, i) => (
          <div
            class:list={[
              'highlight-card group rounded-2xl border bg-gradient-to-br p-8 text-center shadow-sm transition-all duration-300 hover:-translate-y-2 hover:shadow-xl',
              item.bg,
            ]}
            style={`--highlight-accent: ${item.accent}; border-color: ${item.border}; --reveal-delay: ${i * 100}ms`}
            data-reveal="scale"
          >
            <div
              class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-white shadow-sm ring-1 ring-stone-200/80 transition duration-300 group-hover:scale-110 group-hover:shadow-md"
              style={`--tw-ring-color: ${item.accent}33`}
            >
              <DecorIcon name={item.icon} class="h-10 w-10" />
            </div>
            <h3 class="mt-5 text-xl font-black text-stone-900">{item.title}</h3>
            <p class="mt-2.5 text-sm leading-relaxed text-stone-500">{item.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
