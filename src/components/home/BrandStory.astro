---
import AmbientDecor from '../ui/AmbientDecor.astro';
import DecorIcon from '../ui/DecorIcon.astro';

const highlights = [
  {
    title: 'Real Ingredients',
    description: 'Crafted with natural fruit extracts, pure spring water, and no artificial compromises.',
    icon: 'lemon' as const,
    accent: '#84cc16',
    bg: 'from-lime-50 to-green-50',
  },
  {
    title: 'Multiple Sizes',
    description: 'From on-the-go bottles to family-size jugs — refreshment for every occasion.',
    icon: 'ice' as const,
    accent: '#0ea5e9',
    bg: 'from-sky-50 to-cyan-50',
  },
  {
    title: 'Bold Variety',
    description: 'Juices, mocktails, sodas, energy drinks and premium waters under one trusted brand family.',
    icon: 'straw' as const,
    accent: '#16a34a',
    bg: 'from-emerald-50 to-green-50',
  },
];
---

<section class="relative overflow-hidden bg-white py-16 sm:py-24">
  <div class="bg-dots absolute inset-0 opacity-30" aria-hidden="true"></div>
  <div class="bg-blobs absolute inset-0" aria-hidden="true"></div>
  <AmbientDecor variant="light" />

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-bold uppercase tracking-widest text-green-600">Why Arodiya</p>
      <h2 class="mt-3 text-3xl font-black text-stone-900 sm:text-4xl">Made to refresh. Built to impress.</h2>
      <p class="mt-4 text-lg leading-relaxed text-stone-600">
        We bring together the best of Rahat juices, Hayat beverages, and premium energy drinks — delivering
        quality you can taste in every sip.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-3">
      {
        highlights.map((item) => (
          <div
            class:list={[
              'highlight-card group rounded-2xl border border-stone-200 bg-gradient-to-br p-8 text-center shadow-sm transition hover:-translate-y-1 hover:shadow-md',
              item.bg,
            ]}
            style={`--highlight-accent: ${item.accent}`}
          >
            <div
              class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-white shadow-sm ring-1 ring-stone-200/80 transition duration-300 group-hover:scale-110 group-hover:ring-[var(--highlight-accent)]/40"
            >
              <DecorIcon name={item.icon} class="h-10 w-10" />
            </div>
            <h3 class="mt-4 text-xl font-bold text-stone-900">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{item.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>