---
import type { ProductEntry } from '../../lib/products';
import ProductCard from '../products/ProductCard.astro';
import AmbientDecor from '../ui/AmbientDecor.astro';
import { siteConfig } from '../../lib/config';

interface Props {
  entries: ProductEntry[];
}

const { entries } = Astro.props;
const limit = siteConfig.settings.pagination;
const displayedEntries = entries.slice(0, limit);
---

<section id="featured" class="relative overflow-hidden bg-stone-50 py-16 sm:py-24">
  <div class="bg-dots absolute inset-0 opacity-25" aria-hidden="true"></div>
  <AmbientDecor variant="light" />

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Header row -->
    <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between" data-reveal="fade">
      <div>
        <p class="section-label text-sm font-black uppercase tracking-widest text-green-600">Our Range</p>
        <h2 class="mt-2 text-3xl font-black tracking-tight text-stone-900 sm:text-4xl">
          Find Your Flavor
        </h2>
      </div>
      <a
        href="/products"
        class="view-all-link self-start text-sm font-bold text-green-700 hover:text-green-800 sm:self-auto"
      >
        View all products →
      </a>
    </div>

    <!-- Product grid with stagger -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        displayedEntries.map((entry, i) => (
          <div
            data-reveal
            style={`--reveal-delay: ${i * 80}ms`}
          >
            <ProductCard entry={entry} />
          </div>
        ))
      }
    </div>

    <!-- Mobile view all -->
    <div class="mt-10 text-center sm:hidden" data-reveal="fade">
      <a
        href="/products"
        class="btn-shimmer inline-flex items-center gap-2 rounded-full bg-green-600 px-7 py-3 text-sm font-bold text-white shadow-md transition hover:bg-green-700"
      >
        View All Products
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>
