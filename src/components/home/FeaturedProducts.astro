---
import type { ProductEntry } from '../../lib/products';
import ProductCard from '../products/ProductCard.astro';
import { siteConfig } from '../../lib/config';

interface Props {
  entries: ProductEntry[];
}

const { entries } = Astro.props;
const limit = siteConfig.settings.pagination;
---

<section class="bg-stone-50 py-14 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-bold uppercase tracking-widest text-green-600">Key Products</p>
        <h2 class="mt-1 text-3xl font-black text-stone-900">Find Your Flavor</h2>
      </div>
      <a href="/products" class="text-sm font-bold text-green-700 hover:text-green-800">View all →</a>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {entries.slice(0, limit).map((entry) => <ProductCard entry={entry} />)}
    </div>
  </div>
</section>