---
import { getAllProducts, categoryLabels } from '../../lib/products';
import type { ProductCategory } from '../../types/product';

const products = await getAllProducts();

const categoryAccents: Record<ProductCategory, string> = {
  juice: '#f97316',
  mocktail: '#0284c7',
  soda: '#b91c1c',
  energy: '#1d4ed8',
  water: '#0369a1',
};

const categories = (['juice', 'mocktail', 'soda', 'energy', 'water'] as ProductCategory[])
  .map((cat) => {
    const sample = products.find((p) => p.data.category === cat);
    return { key: cat, label: categoryLabels[cat], entry: sample, accent: categoryAccents[cat] };
  })
  .filter((c) => c.entry);
---

<section class="relative overflow-hidden bg-gradient-to-b from-stone-50 to-white py-20 sm:py-28">
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="mb-12 text-center" data-reveal="fade">
      <p class="section-label text-sm font-black uppercase tracking-widest text-green-600">Collections</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-stone-900 sm:text-4xl lg:text-5xl">
        Browse by Category
      </h2>
      <p class="mt-4 text-base text-stone-500">Discover the perfect drink for every taste and occasion.</p>
    </div>

    <!-- Category grid -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        categories.map(({ key, label, entry, accent }, i) => (
          <a
            href={`/products?category=${key}`}
            class="group relative block overflow-hidden rounded-2xl shadow-md transition-all duration-300 hover:-translate-y-1.5 hover:shadow-2xl"
            data-reveal
            style={`--reveal-delay: ${i * 75}ms`}
          >
            <!-- Image -->
            <div class="relative aspect-[4/3] w-full overflow-hidden">
              <img
                src={entry!.data.image}
                alt={entry!.data.name}
                class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
                loading="lazy"
              />
              <!-- Overlay -->
              <div class="category-overlay absolute inset-0"></div>

              <!-- Color accent top line -->
              <div
                class="absolute left-0 top-0 h-1 w-full origin-left scale-x-0 transition-transform duration-400 group-hover:scale-x-100"
                style={`background: ${accent}`}
              ></div>
            </div>

            <!-- Card content -->
            <div class="absolute inset-x-0 bottom-0 p-5">
              <div class="flex items-end justify-between">
                <div>
                  <h3 class="text-xl font-black text-white drop-shadow">{label}</h3>
                  <p class="mt-0.5 text-sm font-medium text-white/80">
                    {products.filter(p => p.data.category === key).length} products
                  </p>
                </div>
                <span
                  class="flex h-9 w-9 items-center justify-center rounded-full bg-white/20 text-white opacity-0 backdrop-blur-sm transition duration-300 group-hover:opacity-100 group-hover:translate-x-0 translate-x-2"
                  aria-hidden="true"
                >
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
