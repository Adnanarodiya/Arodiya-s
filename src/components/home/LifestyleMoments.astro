---
import DecorIcon from '../ui/DecorIcon.astro';

const moments = [
  {
    title: 'BBQ Nights',
    drink: 'Ice-cold Cola',
    icons: ['burger', 'fries'] as const,
    href: '/products?category=soda',
    bg: 'from-amber-50 to-orange-50',
    accent: '#d97706',
  },
  {
    title: 'Pizza Party',
    drink: 'Fruity Mocktail',
    icons: ['pizza', 'straw'] as const,
    href: '/products?category=mocktail',
    bg: 'from-rose-50 to-red-50',
    accent: '#e11d48',
  },
  {
    title: 'Summer Chill',
    drink: 'Fresh Juice',
    icons: ['cone', 'lemon'] as const,
    href: '/products?category=juice',
    bg: 'from-sky-50 to-lime-50',
    accent: '#16a34a',
  },
  {
    title: 'Movie Night',
    drink: 'Energy Boost',
    icons: ['popcorn', 'ice'] as const,
    href: '/products?category=energy',
    bg: 'from-violet-50 to-indigo-50',
    accent: '#7c3aed',
  },
];
---

<section class="relative overflow-hidden bg-white py-16 sm:py-24">
  <div class="bg-dots absolute inset-0 opacity-40" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-bold uppercase tracking-widest text-green-600">Every Moment</p>
      <h2 class="mt-2 text-3xl font-black text-stone-900 sm:text-4xl">Sip. Snack. Enjoy.</h2>
      <p class="mt-3 text-lg text-stone-600">
        Great drinks belong with great moments — pair your favorite flavor with the food you love.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        moments.map((moment) => (
          <a
            href={moment.href}
            class:list={[
              'lifestyle-card group relative overflow-hidden rounded-xl border border-stone-200 bg-gradient-to-br p-6 shadow-sm transition',
              moment.bg,
            ]}
            style={`--moment-accent: ${moment.accent}`}
          >
            <div class="lifestyle-icons flex items-center justify-center gap-3 py-4">
              {moment.icons.map((icon) => (
                <div class="lifestyle-icon-wrap rounded-2xl bg-white/80 p-3 shadow-sm backdrop-blur transition duration-300 group-hover:-translate-y-1 group-hover:scale-110">
                  <DecorIcon name={icon} class="h-12 w-12" />
                </div>
              ))}
            </div>
            <h3 class="text-center text-lg font-bold text-stone-900">{moment.title}</h3>
            <p class="mt-1 text-center text-sm font-medium" style={`color: ${moment.accent}`}>
              + {moment.drink}
            </p>
            <p class="mt-4 text-center text-xs font-bold uppercase tracking-wider text-stone-500 opacity-0 transition group-hover:opacity-100">
              Explore pairings →
            </p>
          </a>
        ))
      }
    </div>
  </div>
</section>